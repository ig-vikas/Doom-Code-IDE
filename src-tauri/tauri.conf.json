{
  "$schema": "https://raw.githubusercontent.com/nicklimmm/tauri/feat/schema/host/tooling/cli/schema.json",
  "productName": "Doom Code",
  "version": "1.0.0",
  "identifier": "com.doomcode.ide",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Doom Code",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "decorations": false,
        "transparent": false,
        "dragDropEnabled": false,
        "windowClassname": "DoomCode"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "fileAssociations": [
      {
        "ext": ["cpp", "c", "h", "hpp", "cc", "cxx", "txt"],
        "mimeType": "text/plain"
      }
    ]
  }
}
